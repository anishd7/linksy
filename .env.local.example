# Supabase Postgres connection string
# Get this from: Supabase Dashboard > Settings > Database > Connection string
# Use the "Transaction" pooler (port 6543) for serverless/production
# Use the "Direct" connection (port 5432) for migrations or local dev
POSTGRES_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Base URL for shareable game links
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Upstash Redis (for leaderboard cache)
# Get these from: console.upstash.com > Your Database > REST API
UPSTASH_REDIS_REST_URL=https://[YOUR-ENDPOINT].upstash.io
UPSTASH_REDIS_REST_TOKEN=[YOUR-TOKEN]
